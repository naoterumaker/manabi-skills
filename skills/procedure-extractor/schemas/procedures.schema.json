{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "procedures.schema.json",
  "title": "Procedures",
  "description": "チャプターごとのUIウォークスルー・操作手順の定義",
  "type": "object",
  "required": ["chapter_id", "procedures"],
  "properties": {
    "chapter_id": {
      "type": "string",
      "description": "チャプター番号（例: \"06\"）",
      "pattern": "^[0-9]{2}$"
    },
    "procedures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/procedure"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "procedure": {
      "type": "object",
      "required": ["id", "title", "steps", "outcome", "tags", "difficulty"],
      "properties": {
        "id": {
          "type": "string",
          "description": "手順ID。p{chapter_id}-{連番} 形式",
          "pattern": "^p[0-9]{2}-[0-9]{2}$"
        },
        "title": {
          "type": "string",
          "description": "手順の目的を表す簡潔なタイトル",
          "minLength": 1
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          },
          "minItems": 1,
          "maxItems": 8
        },
        "outcome": {
          "type": "string",
          "description": "この手順を完了すると何が起きるか",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "description": "具体的なタグ（ツール名・機能名）"
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^c[0-9]{2}-[0-9]{2}$"
          },
          "description": "前提となるconcept ID"
        },
        "difficulty": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced"],
          "description": "難易度レベル"
        }
      },
      "additionalProperties": false
    },
    "step": {
      "type": "object",
      "required": ["step", "action", "screenshot_ref"],
      "properties": {
        "step": {
          "type": "integer",
          "minimum": 1,
          "description": "ステップ番号（1始まり）"
        },
        "action": {
          "type": "string",
          "description": "具体的な操作内容",
          "minLength": 1
        },
        "screenshot_ref": {
          "type": ["string", "null"],
          "description": "対応するフレームファイル名。スクショなしの場合はnull"
        },
        "resource_ref": {
          "type": ["string", "null"],
          "description": "外部リソースファイルパス（resources-manifest.jsonと対応）。リソース参照なしの場合はnull"
        }
      },
      "additionalProperties": false
    }
  }
}
